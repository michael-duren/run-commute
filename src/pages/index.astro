---
// Run-commute gear check — Janji Revy Pack.
// Items are ordered by when they're needed, start of the run → desk → run home.
// zone maps each item to a pocket region on the pack diagram below.

type Item = {
  id: string;
  emoji: string;
  name: string;
  zone: 'chest' | 'slash' | 'strap' | 'mesh' | 'sleeve' | 'main' | 'wear';
  note?: string;
  added?: boolean;
};

type Stage = { n: string; title: string; note?: string; items: Item[] };

const stages: Stage[] = [
  {
    n: '01',
    title: 'Grab-first',
    note: 'needed during the run',
    items: [
      { id: 'phone', emoji: '📱', name: 'Phone', zone: 'chest' },
      { id: 'keys', emoji: '🔑', name: 'Keys', zone: 'slash' },
      { id: 'id-cash', emoji: '💳', name: 'ID + card / cash', zone: 'slash' },
      { id: 'water', emoji: '💧', name: 'Water — 500 ml SoftFlask', zone: 'strap' },
      { id: 'cap', emoji: '🧢', name: 'Cap', zone: 'wear' },
      { id: 'watch', emoji: '⌚', name: 'GPS watch', zone: 'wear', added: true },
      { id: 'headphones', emoji: '🎧', name: 'Headphones', zone: 'wear', added: true },
      { id: 'balm', emoji: '🧴', name: 'Anti-chafe balm', zone: 'wear', note: 'apply before leaving' },
      { id: 'sunscreen', emoji: '☀️', name: 'Sunscreen', zone: 'wear', note: 'apply before leaving', added: true },
    ],
  },
  {
    n: '02',
    title: 'Arrival — shower',
    items: [
      { id: 'deodorant', emoji: '🫧', name: 'Deodorant', zone: 'main' },
      { id: 'towel', emoji: '🛁', name: 'Small towel', zone: 'main', added: true },
      { id: 'soap', emoji: '🧼', name: 'Travel soap / shampoo', zone: 'main', added: true },
    ],
  },
  {
    n: '03',
    title: 'Getting dressed',
    items: [
      { id: 'underwear', emoji: '🧦', name: 'Underwear + socks', zone: 'main' },
      { id: 'top', emoji: '👔', name: 'Work top', zone: 'main', note: 'rolled, not folded' },
      { id: 'bottoms', emoji: '👖', name: 'Work bottoms', zone: 'main', note: 'wallet in the pocket' },
      { id: 'belt', emoji: '🪢', name: 'Belt', zone: 'main' },
      { id: 'shoes', emoji: '👞', name: 'Work shoes', zone: 'mesh' },
      { id: 'badge', emoji: '🪪', name: 'Work badge', zone: 'slash', added: true },
    ],
  },
  {
    n: '04',
    title: 'At the desk',
    items: [
      { id: 'laptop', emoji: '💻', name: 'Laptop + charger', zone: 'sleeve' },
      { id: 'lunch', emoji: '🥪', name: 'Lunch / snacks', zone: 'main' },
      { id: 'meds', emoji: '💊', name: 'Meds / vitamins', zone: 'main' },
    ],
  },
  {
    n: '05',
    title: 'Running back',
    items: [
      { id: 'run-shorts', emoji: '🩳', name: 'Run shorts', zone: 'main' },
      { id: 'run-tee', emoji: '👕', name: 'Run tee', zone: 'main' },
    ],
  },
  {
    n: '∞',
    title: 'Lives in the pack',
    note: 'check they made it back in',
    items: [
      { id: 'wet-bag', emoji: '🛍️', name: 'Wet bag for sweaty clothes', zone: 'main' },
      { id: 'microfiber', emoji: '🧽', name: 'Small microfiber cloth', zone: 'main' },
      { id: 'ziplock', emoji: '☔', name: 'Spare zip-lock (phone rain cover)', zone: 'main' },
      { id: 'plasters', emoji: '🩹', name: 'Blister plasters', zone: 'main', added: true },
    ],
  },
];

const zoneLabels: Record<string, string> = {
  chest: 'front zip chest pocket',
  slash: 'top slash pocket',
  strap: 'drop-in strap pocket',
  mesh: 'external mesh pocket',
  sleeve: 'laptop sleeve',
  main: 'main compartment',
  wear: 'on you',
};

const total = stages.reduce((sum, s) => sum + s.items.length, 0);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Run Commute — gear check</title>
    <meta name="theme-color" content="#edf0f2" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎒</text></svg>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wdth,wght@62..125,100..900&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="wrap">
      <header class="masthead">
        <p class="eyebrow">Janji Revy Pack · door to desk</p>
        <h1>Run&nbsp;commute</h1>
      </header>

      <div class="statusbar">
        <div class="progress" role="progressbar" aria-label="Items packed" aria-valuemin="0" aria-valuemax={total} aria-valuenow="0">
          <div class="progress-fill" id="progress-fill"></div>
        </div>
        <p class="count"><span id="packed-count">0</span> of {total} packed</p>
        <button type="button" id="reset" class="reset">Reset list</button>
      </div>

      <div class="layout">
        <section class="checklist" aria-label="Packing checklist">
          {stages.map((stage) => (
            <section class="stage">
              <header class="stage-head">
                <span class="stage-n" aria-hidden="true">{stage.n}</span>
                <h2>{stage.title}</h2>
                {stage.note && <p class="stage-note">{stage.note}</p>}
              </header>
              <ul>
                {stage.items.map((item) => (
                  <li class="item" data-zone={item.zone}>
                    <label>
                      <input type="checkbox" class="check" data-id={item.id} data-zone={item.zone} />
                      <span class="chip" aria-hidden="true">{item.emoji}</span>
                      <span class="item-body">
                        <span class="item-name">
                          {item.name}
                          {item.added && <span class="tag-added">added</span>}
                        </span>
                        {item.note && <span class="item-note">{item.note}</span>}
                      </span>
                      <span class="pocket">{zoneLabels[item.zone]}</span>
                    </label>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </section>

        <aside class="packmap" aria-label="Where things go in the pack">
          <details id="packmap-toggle">
            <summary class="packmap-title">Where it goes</summary>
          <svg viewBox="0 0 560 430" role="img" aria-label="Diagram of the Revy Pack: harness front and pack back with pocket locations">
            <defs>
              <pattern id="mesh" width="10" height="10" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
                <line x1="0" y1="0" x2="0" y2="10" stroke="currentColor" stroke-width="1" opacity="0.25" />
              </pattern>
            </defs>

            <!-- ============ FRONT / HARNESS ============ -->
            <text class="view-label" x="171" y="34" text-anchor="middle">FRONT · HARNESS</text>
            <!-- yoke connecting the straps over the shoulders -->
            <path class="pack-body" d="M84 78 Q 171 46 258 78 L 258 108 Q 171 78 84 108 Z" />
            <!-- shoulder straps -->
            <path class="pack-body" d="M84 90 C 74 170, 80 260, 100 344 L 144 344 C 128 260, 124 170, 130 90 Z" />
            <path class="pack-body" d="M258 90 C 268 170, 262 260, 242 344 L 198 344 C 214 260, 218 170, 212 90 Z" />
            <!-- chest zip pocket (left strap) -->
            <g class="zone" data-zone="chest">
              <rect x="88" y="130" width="42" height="88" rx="10" />
              <text class="zone-name" x="109" y="168" text-anchor="middle">PHONE</text>
              <text class="zone-count" data-zone-count="chest" x="109" y="186" text-anchor="middle">0/0</text>
            </g>
            <!-- drop-in strap pocket (right strap) -->
            <g class="zone" data-zone="strap">
              <rect x="212" y="124" width="42" height="96" rx="20" />
              <text class="zone-name" x="233" y="164" text-anchor="middle">FLASK</text>
              <text class="zone-count" data-zone-count="strap" x="233" y="182" text-anchor="middle">0/0</text>
            </g>
            <!-- on-you chip -->
            <g class="zone zone-wear" data-zone="wear">
              <rect x="96" y="368" width="150" height="42" rx="21" />
              <text class="zone-name" x="171" y="386" text-anchor="middle">ON YOU</text>
              <text class="zone-count" data-zone-count="wear" x="171" y="402" text-anchor="middle">0/0</text>
            </g>

            <!-- ============ BACK / PACK BODY ============ -->
            <text class="view-label" x="435" y="34" text-anchor="middle">BACK · PACK</text>
            <path class="pack-body pack-main-body" d="M330 66 Q 435 44 540 66 L 532 340 Q 435 366 338 340 Z" />
            <!-- laptop sleeve: rear layer tab peeking over the top -->
            <g class="zone" data-zone="sleeve">
              <path d="M344 64 Q 435 46 526 64 L 524 92 Q 435 76 346 92 Z" />
              <text class="zone-name" x="435" y="80" text-anchor="middle">LAPTOP SLEEVE ·
                <tspan data-zone-count="sleeve">0/0</tspan>
              </text>
            </g>
            <!-- top slash pocket -->
            <g class="zone" data-zone="slash">
              <path d="M348 104 Q 435 90 522 104 L 518 136 Q 435 124 352 136 Z" />
              <text class="zone-name" x="435" y="122" text-anchor="middle">SLASH POCKET ·
                <tspan data-zone-count="slash">0/0</tspan>
              </text>
            </g>
            <!-- main compartment -->
            <g class="zone" data-zone="main">
              <path d="M352 148 Q 435 136 518 148 L 514 246 Q 435 258 356 246 Z" />
              <text class="zone-name" x="435" y="192" text-anchor="middle">MAIN</text>
              <text class="zone-count" data-zone-count="main" x="435" y="212" text-anchor="middle">0/0</text>
            </g>
            <!-- external mesh pocket -->
            <g class="zone" data-zone="mesh">
              <path class="mesh-shape" d="M358 260 Q 435 272 512 260 L 528 336 Q 435 360 342 336 Z" />
              <path class="mesh-fill" d="M358 260 Q 435 272 512 260 L 528 336 Q 435 360 342 336 Z" fill="url(#mesh)" />
              <text class="zone-name" x="435" y="304" text-anchor="middle">MESH · SHOES</text>
              <text class="zone-count" data-zone-count="mesh" x="435" y="324" text-anchor="middle">0/0</text>
            </g>
          </svg>
            <p class="packmap-hint">Hover or tap an item to light up its pocket.</p>
          </details>
        </aside>
      </div>

      <footer class="foot">
        <p>Packed in the order you'll need it — from the front door to your desk and back.</p>
      </footer>
    </main>

    <style>
      :root {
        --fog: #edf0f2;
        --card: #f9fafb;
        --ink: #16222e;
        --muted: #5c6b78;
        --line: #d4dade;
        --orange: #ff4d1c;
        --orange-soft: #ffe6de;
        --pack: #223444;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        background: var(--fog);
        color: var(--ink);
        font-family: 'Archivo', system-ui, sans-serif;
        font-variation-settings: 'wdth' 100;
        line-height: 1.45;
      }

      .wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: 40px 24px 64px;
      }

      /* ---------- masthead ---------- */
      .masthead { margin-bottom: 20px; }

      .eyebrow {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.75rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
        margin: 0 0 4px;
      }

      h1 {
        font-variation-settings: 'wdth' 125;
        font-weight: 900;
        font-size: clamp(2.6rem, 7vw, 4.4rem);
        line-height: 0.95;
        letter-spacing: -0.02em;
        text-transform: uppercase;
        margin: 0;
      }

      .statusbar {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
        margin-bottom: 36px;
      }

      .progress {
        flex: 1 1 220px;
        height: 10px;
        border-radius: 5px;
        background: var(--line);
        overflow: hidden;
      }

      .progress-fill {
        height: 100%;
        width: 0%;
        background: var(--orange);
        border-radius: 5px;
        transition: width 0.35s ease;
      }

      .count {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.85rem;
        margin: 0;
        white-space: nowrap;
      }

      .reset {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.8rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--ink);
        background: none;
        border: 1.5px solid var(--ink);
        border-radius: 999px;
        padding: 8px 18px;
        cursor: pointer;
        transition: background 0.15s ease, color 0.15s ease;
      }

      .reset:hover { background: var(--ink); color: var(--fog); }

      /* ---------- layout ---------- */
      .layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 400px;
        gap: 40px;
        align-items: start;
      }

      /* ---------- stages ---------- */
      .stage { margin-bottom: 30px; }

      .stage-head {
        display: flex;
        align-items: baseline;
        gap: 12px;
        border-bottom: 2px solid var(--ink);
        padding-bottom: 6px;
        margin-bottom: 6px;
      }

      .stage-n {
        font-variation-settings: 'wdth' 125;
        font-weight: 900;
        font-size: 1.5rem;
        color: var(--orange);
        min-width: 2ch;
      }

      .stage-head h2 {
        font-variation-settings: 'wdth' 118;
        font-weight: 800;
        font-size: 1.15rem;
        text-transform: uppercase;
        letter-spacing: 0.02em;
        margin: 0;
      }

      .stage-note {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.72rem;
        color: var(--muted);
        margin: 0 0 0 auto;
      }

      .stage ul { list-style: none; margin: 0; padding: 0; }

      /* ---------- items ---------- */
      .item label {
        display: grid;
        grid-template-columns: auto auto minmax(0, 1fr) auto;
        grid-template-areas: 'check chip body pocket';
        align-items: center;
        column-gap: 12px;
        padding: 8px 10px;
        border-radius: 10px;
        cursor: pointer;
        transition: background 0.12s ease;
        -webkit-tap-highlight-color: transparent;
        user-select: none;
        -webkit-user-select: none;
      }

      .item label:hover { background: var(--card); }

      .item:has(.check:focus-visible) label {
        outline: 2px solid var(--orange);
        outline-offset: 1px;
      }

      .check {
        grid-area: check;
        appearance: none;
        width: 22px;
        height: 22px;
        flex: none;
        border: 2px solid var(--ink);
        border-radius: 6px;
        display: grid;
        place-content: center;
        cursor: pointer;
        background: #fff;
        transition: background 0.12s ease, border-color 0.12s ease;
      }

      .check::before {
        content: '';
        width: 11px;
        height: 11px;
        transform: scale(0);
        transition: transform 0.12s ease;
        clip-path: polygon(14% 44%, 0 65%, 50% 100%, 100% 16%, 80% 0%, 43% 62%);
        background: #fff;
      }

      .check:checked { background: var(--orange); border-color: var(--orange); }
      .check:checked::before { transform: scale(1); }

      .chip {
        grid-area: chip;
        flex: none;
        width: 34px;
        height: 34px;
        border-radius: 9px;
        background: #fff;
        border: 1px solid var(--line);
        display: grid;
        place-content: center;
        font-size: 19px;
        transition: filter 0.15s ease, opacity 0.15s ease;
      }

      .item-body { grid-area: body; min-width: 0; display: flex; flex-direction: column; }

      .item-name { font-weight: 600; font-size: 0.95rem; }

      .item-note {
        font-size: 0.78rem;
        color: var(--muted);
      }

      .tag-added {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.6rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--orange);
        border: 1px solid currentColor;
        border-radius: 4px;
        padding: 1px 5px;
        margin-left: 8px;
        vertical-align: 2px;
      }

      .pocket {
        grid-area: pocket;
        justify-self: end;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.68rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--muted);
        text-align: right;
      }

      .item:has(.check:checked) .item-name {
        text-decoration: line-through;
        text-decoration-color: var(--orange);
        text-decoration-thickness: 2px;
        color: var(--muted);
      }

      .item:has(.check:checked) .chip {
        filter: grayscale(1);
        opacity: 0.55;
      }

      /* ---------- pack map ---------- */
      .packmap {
        position: sticky;
        top: 24px;
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 20px 20px 14px;
      }

      .packmap-title {
        font-variation-settings: 'wdth' 118;
        font-weight: 800;
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        margin: 0 0 10px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        list-style: none;
        /* summary is a static heading on desktop; it becomes a toggle on mobile */
        pointer-events: none;
        -webkit-tap-highlight-color: transparent;
        user-select: none;
        -webkit-user-select: none;
      }

      .packmap-title::-webkit-details-marker { display: none; }

      .packmap-title::after {
        content: '▾';
        color: var(--orange);
        transition: transform 0.15s ease;
        display: none;
      }

      #packmap-toggle:not([open]) .packmap-title::after { transform: rotate(-90deg); }

      .packmap svg { width: 100%; height: auto; display: block; }

      .packmap-hint {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.68rem;
        color: var(--muted);
        text-align: center;
        margin: 10px 0 0;
      }

      .view-label {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 11px;
        letter-spacing: 0.14em;
        fill: var(--muted);
      }

      .pack-body {
        fill: var(--pack);
        opacity: 0.14;
        stroke: var(--pack);
        stroke-width: 1.5;
      }

      .zone rect,
      .zone path {
        fill: #fff;
        stroke: var(--pack);
        stroke-width: 1.5;
        transition: fill 0.15s ease, stroke 0.15s ease;
      }

      .zone .mesh-fill { fill: url(#mesh); stroke: none; color: var(--pack); }

      .zone-name {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 10.5px;
        font-weight: 500;
        letter-spacing: 0.08em;
        fill: var(--ink);
        pointer-events: none;
      }

      .zone-count {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 11px;
        fill: var(--muted);
        pointer-events: none;
      }

      .zone.active rect,
      .zone.active path:not(.mesh-fill) {
        fill: var(--orange-soft);
        stroke: var(--orange);
        stroke-width: 2.5;
      }

      .zone.active .zone-name { fill: var(--orange); }

      .zone.done .zone-count { fill: var(--orange); font-weight: 500; }

      /* ---------- footer ---------- */
      .foot {
        margin-top: 40px;
        border-top: 1px solid var(--line);
        padding-top: 16px;
      }

      .foot p {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.72rem;
        color: var(--muted);
        margin: 0;
      }

      /* ---------- responsive ---------- */
      @media (max-width: 860px) {
        .wrap { padding: 24px 16px 48px; }

        h1 { font-size: clamp(1.8rem, 8.5vw, 2.8rem); }

        .layout { grid-template-columns: 1fr; gap: 20px; }

        /* progress + reset pin to the top while scrolling the list */
        .statusbar {
          position: sticky;
          top: 0;
          z-index: 10;
          background: var(--fog);
          margin: 0 -16px 20px;
          padding: 12px 16px;
          gap: 12px;
          border-bottom: 1px solid var(--line);
        }

        /* bar on its own row; count left, reset right beneath it */
        .progress { flex-basis: 100%; }
        .count { font-size: 0.78rem; }
        .reset { padding: 6px 14px; font-size: 0.72rem; margin-left: auto; }

        /* diagram collapses to a tap-to-expand panel above the list */
        .packmap { position: static; order: -1; padding: 14px 16px; }
        .packmap-title { margin: 0; pointer-events: auto; cursor: pointer; }
        .packmap-title::after { display: block; }
        #packmap-toggle[open] .packmap-title { margin-bottom: 10px; }

        /* pocket label drops under the item name instead of hiding */
        .item label {
          grid-template-columns: auto auto minmax(0, 1fr);
          grid-template-areas:
            'check chip body'
            'check chip pocket';
          padding: 10px 8px;
        }

        .pocket {
          justify-self: start;
          text-align: left;
          font-size: 0.62rem;
          margin-top: 2px;
        }

        /* bigger touch targets */
        .check { width: 26px; height: 26px; }
        .check::before { width: 13px; height: 13px; }
        .chip { width: 38px; height: 38px; font-size: 21px; }
      }

      @media (prefers-reduced-motion: reduce) {
        * { transition: none !important; }
      }
    </style>

    <script>
      const KEY = 'run-commute-checks-v1';
      const boxes = Array.from(document.querySelectorAll<HTMLInputElement>('input.check'));
      const fill = document.getElementById('progress-fill')!;
      const bar = document.querySelector('.progress')!;
      const countEl = document.getElementById('packed-count')!;

      function load(): Set<string> {
        try {
          return new Set(JSON.parse(localStorage.getItem(KEY) ?? '[]'));
        } catch {
          return new Set();
        }
      }

      function persist() {
        const checked = boxes.filter((b) => b.checked).map((b) => b.dataset.id);
        localStorage.setItem(KEY, JSON.stringify(checked));
      }

      function update() {
        const packed = boxes.filter((b) => b.checked).length;
        countEl.textContent = String(packed);
        fill.style.width = `${(packed / boxes.length) * 100}%`;
        bar.setAttribute('aria-valuenow', String(packed));

        // per-pocket counts on the diagram
        const zones = new Map<string, { packed: number; total: number }>();
        for (const b of boxes) {
          const z = b.dataset.zone!;
          const entry = zones.get(z) ?? { packed: 0, total: 0 };
          entry.total += 1;
          if (b.checked) entry.packed += 1;
          zones.set(z, entry);
        }
        for (const [zone, { packed: p, total: t }] of zones) {
          document.querySelectorAll(`[data-zone-count="${zone}"]`).forEach((el) => {
            el.textContent = `${p}/${t}`;
          });
          document.querySelectorAll(`.zone[data-zone="${zone}"]`).forEach((el) => {
            el.classList.toggle('done', p === t);
          });
        }
      }

      // restore saved state
      const saved = load();
      for (const b of boxes) {
        b.checked = saved.has(b.dataset.id!);
        b.addEventListener('change', () => {
          persist();
          update();
        });
      }

      // hover / focus an item -> light up its pocket on the diagram
      for (const li of document.querySelectorAll<HTMLElement>('.item')) {
        const zone = li.dataset.zone;
        const targets = document.querySelectorAll(`.zone[data-zone="${zone}"]`);
        const on = () => targets.forEach((z) => z.classList.add('active'));
        const off = () => targets.forEach((z) => z.classList.remove('active'));
        li.addEventListener('mouseenter', on);
        li.addEventListener('mouseleave', off);
        li.addEventListener('focusin', on);
        li.addEventListener('focusout', off);
      }

      // pack diagram: always open on desktop, collapsed by default on phones
      const packmap = document.getElementById('packmap-toggle') as HTMLDetailsElement;
      const mobile = matchMedia('(max-width: 860px)');
      const syncPackmap = () => {
        packmap.open = !mobile.matches;
      };
      syncPackmap();
      mobile.addEventListener('change', syncPackmap);

      document.getElementById('reset')!.addEventListener('click', () => {
        boxes.forEach((b) => (b.checked = false));
        persist();
        update();
      });

      update();
    </script>
  </body>
</html>
